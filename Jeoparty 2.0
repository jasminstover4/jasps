<!doctype html>
<html lang="en"><head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Jeopardy Game Night</title>
  <script src="https://cdn.tailwindcss.com/3.4.17"></script>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&amp;display=swap" rel="stylesheet">
  <style>
        body { font-family: 'DM Sans', sans-serif; }
        .cell-used { opacity: 0.3; pointer-events: none; }
        .board-cell { cursor: pointer; transition: transform 0.1s, box-shadow 0.1s; }
        .board-cell:hover { transform: scale(1.05); box-shadow: 0 4px 20px rgba(0,0,0,0.3); }
    </style>
  <script src="https://cdn.jsdelivr.net/npm/lucide@0.263.0/dist/umd/lucide.min.js" type="text/javascript"></script>
  <script src="/_sdk/data_sdk.js" type="text/javascript"></script>
  <script src="/_sdk/resizing_sdk.js" type="text/javascript"></script>
 </head>
 <body data-template-id="__page-root" class="w-full min-h-screen p-4" style="background: linear-gradient(135deg, rgb(30, 27, 75), rgb(15, 23, 42));">
  <header class="flex items-center justify-between mb-4 max-w-7xl mx-auto">
   <h1 data-template-id="game-title" class="canva-text text-3xl font-bold" style="color: rgb(250, 204, 21); font-weight: bold; font-style: normal; font-size: 32px;">Jeopardy Game Night</h1><button data-template-id="new-game-btn" class="canva-button px-4 py-2 rounded-lg font-bold" onclick="newGame()" style="background: rgb(250, 204, 21); color: rgb(30, 27, 75); font-weight: bold; font-style: normal; font-size: 16px;">New Game</button>
  </header>
  <div id="board" class="grid grid-cols-6 gap-2 max-w-7xl mx-auto mb-4"></div>
  <div id="scoreboard" class="grid grid-cols-6 gap-2 max-w-7xl mx-auto">
  </div><!-- Question Modal -->
  <div id="modal" class="fixed inset-0 bg-black/80 flex items-center justify-center p-4 hidden z-50">
   <div data-template-id="modal-bg" class="canva-card bg-indigo-900 rounded-2xl p-8 max-w-2xl w-full text-center space-y-6" style="background: rgb(49, 46, 129);">
    <p id="modal-category" class="text-indigo-300 text-sm uppercase tracking-widest"></p>
    <p id="modal-points" class="text-yellow-400 font-bold text-2xl"></p>
    <p id="modal-question" class="text-white text-xl font-medium leading-relaxed"></p>
    <p id="modal-answer" class="text-green-300 text-lg font-bold hidden"></p>
    <div id="modal-actions" class="space-y-4"><button id="reveal-btn" class="bg-yellow-500 text-black px-6 py-2 rounded-lg font-bold" onclick="revealAnswer()">Show Answer</button>
     <div id="team-buttons" class="hidden flex-wrap justify-center gap-2"></div><button class="block mx-auto text-indigo-300 underline mt-2" onclick="closeModal()">Close</button>
    </div>
   </div>
  </div>
  <script src="/_sdk/editing_sdk.js"></script>
  <script>
    const ALL_CATEGORIES = {
        "Pop Culture": [
            {q:"This social media app introduced 'Stories' in 2016, copying Snapchat.",a:"What is Instagram?"},
            {q:"This reality TV family's show ran for 20 seasons on E!",a:"Who are the Kardashians?"},
            {q:"This app became the fastest to reach 100 million users in 2023.",a:"What is Threads?"},
            {q:"This influencer's 'Wednesday' dance went viral on TikTok in 2022.",a:"Who is Jenna Ortega?"},
            {q:"This brand's Stanley cup became the must-have accessory of 2024.",a:"What is Stanley (1913)?"},
            {q:"She broke the internet with her 'Renaissance' world tour.",a:"Who is Beyoncé?"},
            {q:"This dating app uses a 'swipe right' mechanic.",a:"What is Tinder?"},
        ],
        "Cult Classic Films": [
            {q:"'Nobody puts Baby in a corner' is from this 1987 film.",a:"What is Dirty Dancing?"},
            {q:"This 1999 film's first rule is you don't talk about it.",a:"What is Fight Club?"},
            {q:"Jeff Bridges plays 'The Dude' in this Coen Brothers film.",a:"What is The Big Lebowski?"},
            {q:"This 1985 John Hughes film takes place entirely in detention.",a:"What is The Breakfast Club?"},
            {q:"Tim Curry stars as Dr. Frank-N-Furter in this musical horror.",a:"What is Rocky Horror Picture Show?"},
            {q:"This 1988 anime film features Neo-Tokyo and psychic powers.",a:"What is Akira?"},
            {q:"Princess Buttercup appears in this 1987 fairy tale adventure.",a:"What is The Princess Bride?"},
        ],
        "US History": [
            {q:"This purchase from France in 1803 doubled the size of the US.",a:"What is the Louisiana Purchase?"},
            {q:"The 19th Amendment, ratified in 1920, granted this right to women.",a:"What is the right to vote?"},
            {q:"This 1773 protest involved dumping tea into Boston Harbor.",a:"What is the Boston Tea Party?"},
            {q:"He delivered the 'I Have a Dream' speech in 1963.",a:"Who is Martin Luther King Jr.?"},
            {q:"This war lasted from 1861 to 1865 between the North and South.",a:"What is the Civil War?"},
            {q:"The US dropped atomic bombs on these two Japanese cities in 1945.",a:"What are Hiroshima and Nagasaki?"},
            {q:"This document, signed in 1776, declared independence from Britain.",a:"What is the Declaration of Independence?"},
        ],
        "America Did It First": [
            {q:"In 1969, America put the first humans here.",a:"What is the Moon?"},
            {q:"The Wright Brothers achieved this first in 1903 at Kitty Hawk.",a:"What is powered flight?"},
            {q:"Alexander Graham Bell patented this communication device in 1876.",a:"What is the telephone?"},
            {q:"This American invention of 1879 lit up the world.",a:"What is the light bulb?"},
            {q:"ARPANET, created by the US military, became this global network.",a:"What is the Internet?"},
            {q:"Samuel Morse sent the first message using this system in 1844.",a:"What is the telegraph?"},
            {q:"GPS was originally developed by this branch of the US government.",a:"What is the Department of Defense?"},
        ],
        "Sports": [
            {q:"This quarterback has won the most Super Bowls with 7 rings.",a:"Who is Tom Brady?"},
            {q:"This country has won the most FIFA World Cups with 5 titles.",a:"What is Brazil?"},
            {q:"She has the most Grand Slam singles titles in the Open Era with 24.",a:"Who is Margaret Court? (or Serena with 23)"},
            {q:"This NBA player scored 100 points in a single game in 1962.",a:"Who is Wilt Chamberlain?"},
            {q:"The 'Miracle on Ice' happened at this 1980 Winter Olympics location.",a:"What is Lake Placid?"},
            {q:"This sport uses terms like 'birdie', 'eagle', and 'bogey'.",a:"What is golf?"},
            {q:"She is the most decorated gymnast in history with 37 medals.",a:"Who is Simone Biles?"},
        ],
        "Popular Music": [
            {q:"This Taylor Swift album features 'Anti-Hero' and 'Lavender Haze'.",a:"What is Midnights?"},
            {q:"This K-pop group became the best-selling artist worldwide in 2020-2022.",a:"Who is BTS?"},
            {q:"'Blinding Lights' by this artist became the #1 Billboard Hot 100 song of all time.",a:"Who is The Weeknd?"},
            {q:"This Olivia Rodrigo debut single broke Spotify streaming records in 2021.",a:"What is 'drivers license'?"},
            {q:"This rapper's real name is Aubrey Drake Graham.",a:"Who is Drake?"},
            {q:"SZA released this critically acclaimed album in 2022.",a:"What is SOS?"},
            {q:"This Doja Cat song went viral on TikTok featuring the lyric 'I'm a cow'.",a:"What is 'Mooo!'?"},
        ],
        "Marvel Films": [
            {q:"This 2018 film ends with Thanos snapping half of all life away.",a:"What is Avengers: Infinity War?"},
            {q:"This stone controls time in the MCU and was guarded by Doctor Strange.",a:"What is the Time Stone?"},
            {q:"She is the first female-led MCU solo film character.",a:"Who is Captain Marvel?"},
            {q:"This planet is where Thor meets the Grandmaster in Ragnarok.",a:"What is Sakaar?"},
            {q:"Tony Stark says 'I am Iron Man' in this film's climactic scene.",a:"What is Avengers: Endgame?"},
            {q:"This Black Panther actor tragically passed in 2020.",a:"Who is Chadwick Boseman?"},
            {q:"Spider-Man's identity is revealed to the world in this film.",a:"What is Far From Home?"},
        ],
        "Popular Anime": [
            {q:"This anime features a boy who finds a Death Note that kills anyone whose name is written in it.",a:"What is Death Note?"},
            {q:"Monkey D. Luffy searches for the 'One Piece' in this long-running series.",a:"What is One Piece?"},
            {q:"This anime features Titans that eat humans behind giant walls.",a:"What is Attack on Titan?"},
            {q:"Goku is the main character of this iconic fighting anime franchise.",a:"What is Dragon Ball?"},
            {q:"This 2019 anime film became the highest-grossing anime movie in Japan.",a:"What is Demon Slayer: Mugen Train?"},
            {q:"Naruto's dream is to become this leader of his village.",a:"What is Hokage?"},
            {q:"This Studio Ghibli film features a girl working in a bathhouse for spirits.",a:"What is Spirited Away?"},
        ],
        "BookTok": [
            {q:"Colleen Hoover's bestseller about domestic violence features this flower in its title.",a:"What is It Ends with Us?"},
            {q:"This Sarah J. Maas series features Feyre and the Night Court.",a:"What is A Court of Thorns and Roses?"},
            {q:"This dark romance author wrote 'Twisted Love' and the Twisted series.",a:"Who is Ana Huang?"},
            {q:"Madeline Miller retells Achilles' story from Patroclus' perspective in this novel.",a:"What is The Song of Achilles?"},
            {q:"This Ali Hazelwood enemies-to-lovers is set in academia.",a:"What is The Love Hypothesis?"},
            {q:"Adam Silvera's title warns 'they both die' in this book.",a:"What is They Both Die at the End?"},
            {q:"This romantasy by Leigh Bardugo features six criminals on a heist.",a:"What is Six of Crows?"},
        ],
        "TV Shows": [
            {q:"This HBO show about succession of a media empire ran for 4 seasons.",a:"What is Succession?"},
            {q:"Wednesday Addams attends this school in the Netflix series.",a:"What is Nevermore Academy?"},
            {q:"This Korean survival drama became Netflix's most-watched series in 2021.",a:"What is Squid Game?"},
            {q:"Pedro Pascal plays Joel in this post-apocalyptic HBO adaptation.",a:"What is The Last of Us?"},
            {q:"This show features a high school chess prodigy played by Anya Taylor-Joy.",a:"What is The Queen's Gambit?"},
            {q:"Zendaya stars as Rue in this teen drama about addiction.",a:"What is Euphoria?"},
            {q:"This Disney+ show reveals Wanda creating a false reality in Westview.",a:"What is WandaVision?"},
        ],
        "Video Games": [
            {q:"This 2023 Zelda sequel lets Link build vehicles and gadgets in the sky.",a:"What is Tears of the Kingdom?"},
            {q:"This battle royale game features building mechanics and was released by Epic Games.",a:"What is Fortnite?"},
            {q:"Kratos and his son Atreus travel through Norse mythology in this series.",a:"What is God of War?"},
            {q:"This cozy life sim lets you build an island community with animal villagers.",a:"What is Animal Crossing: New Horizons?"},
            {q:"This FromSoftware open-world game won Game of the Year 2022.",a:"What is Elden Ring?"},
            {q:"This indie game about a hollow vessel fighting in Hallownest went viral.",a:"What is Hollow Knight?"},
            {q:"Baldur's Gate 3 is based on this tabletop RPG system.",a:"What is Dungeons & Dragons?"},
        ],
        "Internet & Memes": [
            {q:"This 2024 meme format features a man looking back at another woman while with his girlfriend.",a:"What is Distracted Boyfriend?"},
            {q:"'Is this a pigeon?' comes from this 1990s anime.",a:"What is The Brave Fighter of Sun Fighbird?"},
            {q:"This phrase meaning 'greatest of all time' became internet slang.",a:"What is GOAT?"},
            {q:"This viral 2023 phrase means something is excellent or top-tier.",a:"What is 'slay' or 'ate'?"},
            {q:"Bernie Sanders sitting in mittens became a meme at this 2021 event.",a:"What is the Presidential Inauguration?"},
            {q:"This 'sigma male' meme uses a clip from this Christian Bale film.",a:"What is American Psycho?"},
            {q:"The 'This is fine' meme features a dog sitting in this situation.",a:"What is a fire?"},
        ],
    };

    let teams = [{name:"Team 1",score:0},{name:"Team 2",score:0},{name:"Team 3",score:0},{name:"Team 4",score:0},{name:"Team 5",score:0},{name:"Team 6",score:0}];
    let gameCategories = [];
    let gameQuestions = {};
    let usedCells = new Set();
    let currentQ = null;

    function shuffle(arr) {
        for(let i=arr.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[arr[i],arr[j]]=[arr[j],arr[i]];}
        return arr;
    }

    function newGame() {
        teams.forEach(t=>t.score=0);
        usedCells.clear();
        const catNames = shuffle(Object.keys(ALL_CATEGORIES)).slice(0,6);
        gameCategories = catNames;
        gameQuestions = {};
        catNames.forEach(c=>{
            gameQuestions[c] = shuffle([...ALL_CATEGORIES[c]]).slice(0,5);
        });
        renderBoard();
        renderScoreboard();
    }

    function renderBoard(){
        const board = document.getElementById('board');
        board.innerHTML = '';
        gameCategories.forEach((cat,ci)=>{
            const header = document.createElement('div');
            header.className = 'bg-indigo-800 text-yellow-300 font-bold text-center p-3 rounded-lg text-xs sm:text-sm';
            header.textContent = cat;
            board.appendChild(header);
        });
        for(let row=0;row<5;row++){
            const pts = (row+1)*200;
            gameCategories.forEach((cat,ci)=>{
                const cell = document.createElement('button');
                const key = `${ci}-${row}`;
                cell.className = 'board-cell bg-indigo-700 text-yellow-400 font-bold text-lg sm:text-xl p-4 rounded-lg';
                if(usedCells.has(key)) cell.classList.add('cell-used');
                cell.textContent = '$'+pts;
                cell.onclick = ()=>openQuestion(ci,row,pts);
                board.appendChild(cell);
            });
        }
    }

    function renderScoreboard(){
        const sb = document.getElementById('scoreboard');
        sb.innerHTML = '';
        teams.forEach((t,i)=>{
            const div = document.createElement('div');
            div.className = 'bg-gray-800 text-white rounded-lg p-3 text-center';
            div.innerHTML = `<input class="bg-transparent text-center text-sm font-bold w-full outline-none text-indigo-300" value="${t.name}" onchange="teams[${i}].name=this.value"><div class="text-xl font-bold mt-1 ${t.score<0?'text-red-400':'text-green-400'}">${t.score>=0?'$'+t.score:'-$'+Math.abs(t.score)}</div>`;
            sb.appendChild(div);
        });
    }

    function openQuestion(ci,row,pts){
        const key = `${ci}-${row}`;
        if(usedCells.has(key)) return;
        usedCells.add(key);
        currentQ = {ci,row,pts};
        const q = gameQuestions[gameCategories[ci]][row];
        document.getElementById('modal-category').textContent = gameCategories[ci];
        document.getElementById('modal-points').textContent = '$'+pts;
        document.getElementById('modal-question').textContent = q.q;
        document.getElementById('modal-answer').textContent = q.a;
        document.getElementById('modal-answer').classList.add('hidden');
        document.getElementById('reveal-btn').classList.remove('hidden');
        document.getElementById('team-buttons').classList.add('hidden');
        document.getElementById('modal').classList.remove('hidden');
        renderBoard();
    }

    function revealAnswer(){
        document.getElementById('modal-answer').classList.remove('hidden');
        document.getElementById('reveal-btn').classList.add('hidden');
        const tb = document.getElementById('team-buttons');
        tb.innerHTML = '';
        tb.classList.remove('hidden');
        tb.classList.add('flex');
        teams.forEach((t,i)=>{
            const correct = document.createElement('button');
            correct.className = 'bg-green-600 text-white px-3 py-1 rounded text-sm font-bold';
            correct.textContent = '✓ '+t.name;
            correct.onclick = ()=>{teams[i].score+=currentQ.pts;renderScoreboard();closeModal();};
            tb.appendChild(correct);
        });
        const wrong = document.createElement('button');
        wrong.className = 'bg-red-600 text-white px-3 py-1 rounded text-sm font-bold';
        wrong.textContent = '✗ No one';
        wrong.onclick = ()=>closeModal();
        tb.appendChild(wrong);
    }

    function closeModal(){
        document.getElementById('modal').classList.add('hidden');
    }

    newGame();
    </script>
 <script>(function(){function c(){var b=a.contentDocument||a.contentWindow.document;if(b){var d=b.createElement('script');d.innerHTML="window.__CF$cv$params={r:'9fed09977173181f',t:'MTc3OTI5Nzg5My4wMDAwMDA='};var a=document.createElement('script');a.nonce='';a.src='/cdn-cgi/challenge-platform/scripts/jsd/main.js';document.getElementsByTagName('head')[0].appendChild(a);";b.getElementsByTagName('head')[0].appendChild(d)}}if(document.body){var a=document.createElement('iframe');a.height=1;a.width=1;a.style.position='absolute';a.style.top=0;a.style.left=0;a.style.border='none';a.style.visibility='hidden';document.body.appendChild(a);if('loading'!==document.readyState)c();else if(window.addEventListener)document.addEventListener('DOMContentLoaded',c);else{var e=document.onreadystatechange||function(){};document.onreadystatechange=function(b){e(b);'loading'!==document.readyState&&(document.onreadystatechange=e,c())}}}})();</script>
</body></html>
